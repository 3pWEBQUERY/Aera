            "state": "translated",
            "value": "Odkrywaj społeczności i dołącz do swojej pierwszej."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Descubra comunidades e participe da sua primeira."
          }
        },
        "ru": {
