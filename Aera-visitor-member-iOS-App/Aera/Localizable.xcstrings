    "Sobald Mitglieder Punkte sammeln, erscheint hier die Rangliste.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Så snart medlemmer optjener point, vises ranglisten her."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Once members earn points, the leaderboard will appear here."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Once members earn points, the leaderboard will appear here."
          }
