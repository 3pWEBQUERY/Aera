    "Hier erscheinen Reaktionen und Antworten auf deine Beiträge.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Reaktioner og svar på dine opslag vises her."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reactions and replies to your posts will appear here."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Reactions and replies to your posts will appear here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí aparecerán las reacciones y respuestas a tus publicaciones."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí aparecerán las reacciones y respuestas a tus publicaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les réactions et réponses à vos publications apparaîtront ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le reazioni e le risposte ai tuoi post appariranno qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの投稿へのリアクションや返信はここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "회원님의 게시물에 대한 반응과 답글이 여기에 표시됩니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Reaksjoner og svar på innleggene dine vises her."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Reacties en antwoorden op je berichten verschijnen hier."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutaj pojawią się reakcje i odpowiedzi na Twoje posty."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Reações e respostas às suas publicações aparecerão aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Здесь появятся реакции и ответы на ваши публикации."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Reaktioner och svar på dina inlägg visas här."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тут з’являтимуться реакції та відповіді на ваші дописи."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对你帖子的回应和回复会显示在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對你貼文的回應和回覆會顯示在這裡。"
          }
        }
      }
    },
    "Hier erscheinen alle Mitglieder der Community.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle fællesskabets medlemmer vises her."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All community members will appear here."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "All community members will appear here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí aparecerán todos los miembros de la comunidad."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí aparecerán todos los miembros de la comunidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les membres de la communauté apparaîtront ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti i membri della community appariranno qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コミュニティの全メンバーがここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "커뮤니티의 모든 멤버가 여기에 표시됩니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle medlemmene i fellesskapet vises her."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle leden van de community verschijnen hier."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutaj pojawią się wszyscy członkowie społeczności."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os membros da comunidade aparecerão aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Здесь появятся все участники сообщества."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Alla medlemmar i communityn visas här."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тут з’являться всі учасники спільноти."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "社区的所有成员会显示在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "社群的所有成員會顯示在這裡。"
          }
        }
      }
    },
    "Hier können Mitglieder Wünsche und Ideen einreichen, über die abgestimmt wird.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Her kan medlemmer indsende ønsker og idéer, som der stemmes om."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Here, members can submit wishes and ideas that get voted on."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Here, members can submit wishes and ideas that get voted on."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí los miembros pueden enviar deseos e ideas que se someten a votación."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí los miembros pueden enviar deseos e ideas que se someten a votación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ici, les membres peuvent soumettre des souhaits et des idées soumis au vote."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Qui i membri possono proporre desideri e idee su cui votare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メンバーはここでリクエストやアイデアを投稿し、投票にかけられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "멤버들이 요청과 아이디어를 제출하고 투표할 수 있는 공간입니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Her kan medlemmer sende inn ønsker og ideer som det stemmes over."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hier kunnen leden wensen en ideeën indienen waarover wordt gestemd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutaj członkowie mogą zgłaszać życzenia i pomysły, które są poddawane głosowaniu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aqui os membros podem enviar desejos e ideias que serão votados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Здесь участники могут предлагать пожелания и идеи, за которые проходит голосование."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Här kan medlemmar skicka in önskemål och idéer som det röstas om."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тут учасники можуть подавати побажання та ідеї, за які проходитиме голосування."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "成员可以在这里提交愿望和想法，供大家投票。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "成員可以在這裡提交願望和想法，供大家投票。"
          }
        }
      }
    },
