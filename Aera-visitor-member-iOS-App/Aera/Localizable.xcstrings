          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Så snart medlemmer samler poeng, vises rangeringen her."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zodra leden punten verzamelen, verschijnt hier het klassement."
