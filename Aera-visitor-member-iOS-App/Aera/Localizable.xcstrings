    "Mit der Registrierung akzeptierst du die Nutzungsbedingungen und die Datenschutzerklärung von Aera.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ved at registrere dig accepterer du Aeras brugsbetingelser og privatlivspolitik."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By signing up, you accept Aera's Terms of Use and Privacy Policy."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "By signing up, you accept Aera's Terms of Use and Privacy Policy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al registrarte, aceptas las Condiciones de uso y la Política de privacidad de Aera."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Al registrarte, aceptas las Condiciones de uso y la Política de privacidad de Aera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En vous inscrivant, vous acceptez les Conditions d'utilisation et la Politique de confidentialité d'Aera."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registrandoti accetti le Condizioni d'uso e l'Informativa sulla privacy di Aera."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "登録すると、Aeraの利用規約とプライバシーポリシーに同意したことになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가입하면 Aera의 이용약관과 개인정보 처리방침에 동의하는 것으로 간주됩니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ved å registrere deg godtar du Aeras bruksvilkår og personvernerklæring."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Door je te registreren, accepteer je de gebruiksvoorwaarden en het privacybeleid van Aera."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejestrując się, akceptujesz Warunki korzystania i Politykę prywatności Aera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ao se cadastrar, você aceita os Termos de Uso e a Política de Privacidade do Aera."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Регистрируясь, вы принимаете Условия использования и Политику конфиденциальности Aera."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Genom att registrera dig godkänner du Aeras användarvillkor och integritetspolicy."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Реєструючись, ви приймаєте Умови використання та Політику конфіденційності Aera."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "注册即表示你接受 Aera 的使用条款和隐私政策。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "註冊即表示你接受 Aera 的使用條款和隱私權政策。"
