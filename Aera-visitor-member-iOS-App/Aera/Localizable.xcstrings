    "Werde Mitglied, um %@ zu sehen.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Bliv medlem for at se %@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Become a member to see %@."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Become a member to see %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazte miembro para ver %@."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazte miembro para ver %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Devenez membre pour voir %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Diventa membro per vedere %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@を見るにはメンバーになってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@을(를) 보려면 멤버가 되어 주세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bli medlem for å se %@."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Word lid om %@ te zien."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zostań członkiem, aby zobaczyć %@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Torne-se membro para ver %@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Станьте участником, чтобы увидеть %@."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bli medlem för att se %@."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Станьте учасником, щоб побачити %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "成为会员即可查看%@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "成為會員即可查看%@。"
          }
        }
      }
    },
    "Werde Mitglied, um zuzusagen.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Bliv medlem for at tilmelde dig."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Become a member to RSVP."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Become a member to RSVP."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazte miembro para confirmar tu asistencia."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazte miembro para confirmar tu asistencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Devenez membre pour confirmer votre participation."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Diventa membro per confermare la partecipazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "参加登録にはメンバーになってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "참석하려면 멤버가 되어 주세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bli medlem for å melde deg på."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Word lid om je aan te melden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zostań członkiem, aby potwierdzić udział."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Torne-se membro para confirmar presença."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Станьте участником, чтобы подтвердить участие."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bli medlem för att anmäla dig."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Станьте учасником, щоб підтвердити участь."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "成为会员即可报名参加。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "成為會員即可報名參加。"
          }
        }
      }
    },
    "Wie sollen andere Mitglieder dich sehen?": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvordan skal andre medlemmer se dig?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How should other members see you?"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "How should other members see you?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cómo quieres que te vean los demás miembros?"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cómo quieres que te vean los demás miembros?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comment les autres membres doivent-ils vous voir ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Come devono vederti gli altri membri?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他のメンバーにどのように表示されますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 멤버에게 어떻게 표시할까요?"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvordan skal andre medlemmer se deg?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoe moeten andere leden je zien?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak mają Cię widzieć inni członkowie?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Como os outros membros devem ver você?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как вас будут видеть другие участники?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hur ska andra medlemmar se dig?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Як вас бачитимуть інші учасники?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "其他成员会如何看到你？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "其他成員會如何看到你？"
          }
        }
      }
    },
