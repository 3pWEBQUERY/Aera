    "Dein Konto konnte nicht geladen werden. Ziehe zum Aktualisieren nach unten.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din konto kunne ikke indlæses. Træk ned for at opdatere."
