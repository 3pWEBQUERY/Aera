    "Falls ein Konto mit dieser E-Mail existiert, haben wir dir einen Link zum Zurücksetzen geschickt.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis der findes en konto med denne e-mail, har vi sendt dig et link til nulstilling."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If an account with this email exists, we've sent you a reset link."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "If an account with this email exists, we've sent you a reset link."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si existe una cuenta con este correo, te hemos enviado un enlace para restablecer la contraseña."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Si existe una cuenta con este correo, te hemos enviado un enlace para restablecer la contraseña."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si un compte existe avec cet e-mail, un lien de réinitialisation vous a été envoyé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se esiste un account con questa email, ti abbiamo inviato un link per il ripristino."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このメールアドレスのアカウントが存在する場合、リセット用のリンクを送信しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 이메일로 등록된 계정이 있다면 재설정 링크를 보내 드렸습니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis det finnes en konto med denne e-posten, har vi sendt deg en lenke for tilbakestilling."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als er een account met dit e-mailadres bestaat, hebben we je een herstellink gestuurd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli istnieje konto z tym adresem e-mail, wysłaliśmy link do zresetowania hasła."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se existir uma conta com este e-mail, enviamos um link de redefinição."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если аккаунт с этой почтой существует, мы отправили ссылку для сброса пароля."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Om det finns ett konto med den här e-postadressen har vi skickat en återställningslänk."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо обліковий запис із цією поштою існує, ми надіслали посилання для скидання пароля."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
