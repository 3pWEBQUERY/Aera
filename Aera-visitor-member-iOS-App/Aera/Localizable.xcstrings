          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu cuenta está protegida con autenticación de dos factores. Introduce el código de 6 dígitos de tu app de autenticación."
          }
        },
        "es-419": {
          "stringUnit": {
