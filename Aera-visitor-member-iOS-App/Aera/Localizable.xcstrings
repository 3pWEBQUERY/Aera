    "Entdecke Communities und tritt deiner ersten bei.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Opdag fællesskaber, og bliv medlem af dit første."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discover communities and join your first one."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Discover communities and join your first one."
          }
        },
        "es": {
