    "Suche nach Beiträgen, Kursen, Events, Produkten und Wissensartikeln.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Søg efter opslag, kurser, events, produkter og vidensartikler."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search for posts, courses, events, products, and knowledge articles."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Search for posts, courses, events, products, and knowledge articles."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Busca publicaciones, cursos, eventos, productos y artículos de conocimiento."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Busca publicaciones, cursos, eventos, productos y artículos de conocimiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recherchez des publications, cours, événements, produits et articles de connaissances."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerca post, corsi, eventi, prodotti e articoli informativi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "投稿・コース・イベント・製品・ナレッジ記事を検索できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "게시물, 강의, 이벤트, 제품, 지식 아티클을 검색해 보세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Søk etter innlegg, kurs, arrangementer, produkter og kunnskapsartikler."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zoek naar berichten, cursussen, evenementen, producten en kennisartikelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Szukaj postów, kursów, wydarzeń, produktów i artykułów bazy wiedzy."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Busque publicações, cursos, eventos, produtos e artigos de conhecimento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ищите публикации, курсы, события, товары и справочные статьи."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sök efter inlägg, kurser, evenemang, produkter och kunskapsartiklar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Шукайте дописи, курси, події, товари та довідкові статті."
          }
        },
        "zh-Hans": {
          "stringUnit": {
