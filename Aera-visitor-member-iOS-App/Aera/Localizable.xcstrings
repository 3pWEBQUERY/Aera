    "Leer lassen für die Produktions-URL. Änderungen gelten für neue Anfragen.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lad stå tomt for produktions-URL'en. Ændringer gælder for nye forespørgsler."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave empty for the production URL. Changes apply to new requests."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave empty for the production URL. Changes apply to new requests."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Déjalo vacío para usar la URL de producción. Los cambios se aplican a las nuevas solicitudes."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Déjalo vacío para usar la URL de producción. Los cambios se aplican a las nuevas solicitudes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laisser vide pour l'URL de production. Les modifications s'appliquent aux nouvelles requêtes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lascia vuoto per l'URL di produzione. Le modifiche si applicano alle nuove richieste."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本番URLを使う場合は空欄のままにしてください。変更は新しいリクエストに適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프로덕션 URL을 사용하려면 비워 두세요. 변경 사항은 새 요청부터 적용됩니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "La stå tomt for produksjons-URL-en. Endringer gjelder for nye forespørsler."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Laat leeg voor de productie-URL. Wijzigingen gelden voor nieuwe verzoeken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pozostaw puste, aby użyć produkcyjnego adresu URL. Zmiany dotyczą nowych żądań."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixe vazio para a URL de produção. As alterações valem para novas solicitações."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оставьте пустым для рабочего URL. Изменения применяются к новым запросам."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lämna tomt för produktions-URL:en. Ändringar gäller för nya förfrågningar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Залиште порожнім для робочого URL. Зміни застосовуються до нових запитів."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "留空则使用生产环境 URL。更改对新请求生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "留空則使用正式環境 URL。變更對新請求生效。"
          }
        }
      }
    },
