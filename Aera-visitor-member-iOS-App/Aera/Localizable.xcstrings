    "Käufe rechnen über Apple ab. Abos verlängern sich automatisch und sind in den App-Store-Einstellungen kündbar.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Køb afregnes via Apple. Abonnementer fornyes automatisk og kan opsiges i App Store-indstillingerne."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Purchases are billed through Apple. Subscriptions renew automatically and can be canceled in your App Store settings."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Purchases are billed through Apple. Subscriptions renew automatically and can be cancelled in your App Store settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las compras se cobran a través de Apple. Las suscripciones se renuevan automáticamente y se pueden cancelar en los ajustes del App Store."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Las compras se cobran a través de Apple. Las suscripciones se renuevan automáticamente y se pueden cancelar en la configuración del App Store."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les achats sont facturés via Apple. Les abonnements se renouvellent automatiquement et peuvent être résiliés dans les réglages de l'App Store."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli acquisti vengono addebitati tramite Apple. Gli abbonamenti si rinnovano automaticamente e possono essere annullati nelle impostazioni dell'App Store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入はApple経由で請求されます。サブスクリプションは自動的に更新され、App Storeの設定で解約できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구매는 Apple을 통해 결제됩니다. 구독은 자동으로 갱신되며 App Store 설정에서 해지할 수 있습니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kjøp belastes via Apple. Abonnementer fornyes automatisk og kan sies opp i App Store-innstillingene."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aankopen worden via Apple afgerekend. Abonnementen verlengen automatisch en kunnen in de App Store-instellingen worden opgezegd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zakupy są rozliczane przez Apple. Subskrypcje odnawiają się automatycznie i można je anulować w ustawieniach App Store."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As compras são cobradas pela Apple. As assinaturas são renovadas automaticamente e podem ser canceladas nos ajustes da App Store."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Покупки оплачиваются через Apple. Подписки продлеваются автоматически; отменить их можно в настройках App Store."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Köp debiteras via Apple. Prenumerationer förnyas automatiskt och kan sägas upp i App Store-inställningarna."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Покупки оплачуються через Apple. Підписки поновлюються автоматично; скасувати їх можна в налаштуваннях App Store."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "购买通过 Apple 结算。订阅会自动续订，可在 App Store 设置中取消。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "購買透過 Apple 結算。訂閱會自動續訂，可在 App Store 設定中取消。"
          }
        }
      }
    },
