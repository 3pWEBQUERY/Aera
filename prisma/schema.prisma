// Aera.so — Multi-Tenant Creator Platform
// Prisma 7 (Rust-free, prisma-client generator + pg driver adapter)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url is configured in prisma.config.ts (Prisma 7)
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------
enum Role {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum MemberStatus {
  ACTIVE
  PENDING
  BANNED
}

enum PlatformRole {
  USER
  ADMIN
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETING
}

enum SpaceType {
  FEED
  FORUM
  COURSE
  SHOP
  NEWSLETTER
  EVENTS
  BLOG
  KNOWLEDGE
  GALLERY
  VIDEOS
  CHAT
  PODCAST
  LINKS
  ADS
  LIVE
  REQUESTS
  BOOKING
  STORIES
  TIPS
  CALENDAR
}

enum Visibility {
  PUBLIC // anyone, even logged out
  MEMBERS // any logged-in member of the tenant
  PAID // requires a tier/entitlement
}

enum BillingInterval {
  FREE
  MONTH
  YEAR
  ONE_TIME
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum StripeWebhookStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum WebhookDeliveryStatus {
  PENDING
  PROCESSING
  RETRYING
  DELIVERED
  EXHAUSTED
}

enum AutomationDeliveryStatus {
  PENDING
  PROCESSING
  RETRYING
  SENT
  SUPPRESSED
  EXHAUSTED
}

enum NewsletterDeliveryStatus {
  PENDING
  PROCESSING
  RETRYING
  SENT
  SUPPRESSED
  EXHAUSTED
}

enum NewsletterConsentStatus {
  OPTED_IN
  WITHDRAWN
}

enum NewsletterConsentEventType {
  OPTED_IN
  WITHDRAWN
}

enum EmailSuppressionReason {
  UNSUBSCRIBED
  BOUNCE
  COMPLAINT
  MANUAL
}

enum CronJobStatus {
  IDLE
  RUNNING
  SUCCEEDED
  FAILED
}

enum AccountStatus {
  ACTIVE
  DELETING
  DELETED
}

enum DataDeletionScope {
  TENANT
  USER
}

enum DataDeletionStatus {
  PENDING
  PROCESSING
  RETRYING
  BLOCKED
  COMPLETED
}

enum ObjectDeletionStatus {
  PENDING
  PROCESSING
  RETRYING
  COMPLETED
  EXHAUSTED
}

enum AiCreditReservationStatus {
  RESERVED
  SETTLED
  RELEASED
}

enum AiCreditSource {
  INCLUDED
  PURCHASED
}

enum EntitlementSource {
  TIER
  PURCHASE
  MANUAL
  ROLE
}

enum ProductType {
  DIGITAL
  PHYSICAL
  BUNDLE
  COURSE_ACCESS
  TIER_GRANT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
}

enum EmailEventType {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  SUPPRESSED
  FAILED
}

enum GamificationTrigger {
  POST_CREATED
  COMMENT_CREATED
  REACTION_GIVEN
  LESSON_COMPLETED
  EVENT_RSVP
  DAILY_LOGIN
  PURCHASE
  REFERRAL // ein geworbenes Mitglied ist beigetreten
  TIP // Trinkgeld gegeben
}

enum RsvpStatus {
  GOING
  INTERESTED
  NOT_GOING
}

enum LiveStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum StorageVisibility {
  PUBLIC
  MEMBERS
  PAID
}

enum StorageUploadStatus {
  RESERVED
  COMPLETED
  FAILED
  EXPIRED
}

// Creator subscription package — determines the monthly AI credit allowance.
enum CreatorPlan {
  FREE
  STARTER
  PRO
  SCALE
}

enum CreatorCheckoutStatus {
  CREATING
  OPEN
  COMPLETED
  EXPIRED
  FAILED
}

// ----------------------------------------------------------------------------
// Global (tenant-neutral) identity
// ----------------------------------------------------------------------------
model User {
  id              String        @id @default(cuid())
  email           String        @unique
  passwordHash    String
  name            String
  avatarUrl       String?
  /// Set once the user proved control of their mailbox (verification link,
  /// accepted invite, or completed password reset). Null = unverified.
  emailVerifiedAt DateTime?
  /// Zwei-Faktor (TOTP, RFC 6238): Base32-Secret; gesetzt ab Einrichtung.
  totpSecret      String?
  /// 2FA aktiv ab diesem Zeitpunkt (nach bestätigtem Einrichtungs-Code).
  totpEnabledAt   DateTime?
  /// Incrementing this invalidates every previously issued session token.
  sessionVersion  Int           @default(0)
  /// Plattformweite Berechtigung. ADMIN ist nur zusammen mit verifizierter
  /// E-Mail und aktivem TOTP wirksam (siehe lib/platform-admin.ts).
  platformRole    PlatformRole  @default(USER)
  /// DELETING/DELETED identities cannot authenticate. Deletion jobs keep a
  /// pseudonymous tombstone where billing/content foreign keys require one.
  accountStatus   AccountStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  memberships               Membership[]
  ownedTenants              Tenant[]                   @relation("TenantOwner")
  posts                     Post[]
  comments                  Comment[]
  reactions                 Reaction[]
  orders                    Order[]
  subscriptions             Subscription[]
  entitlements              Entitlement[]
  pointsLedger              PointsLedger[]
  badgeAwards               BadgeAward[]
  memberStats               MemberStats[]
  lessonProgress            LessonProgress[]
  eventRsvps                EventRsvp[]
  liveMessages              LiveChatMessage[]
  recommendations           Recommendation[]
  emailEvents               EmailEvent[]
  storageObjects            StorageObject[]
  storageUploadReservations StorageUploadReservation[]
  campaigns                 NewsletterCampaign[]
  automationDeliveries      AutomationDelivery[]
  chatMessages              ChatMessage[]
  conversationMembers       ConversationMember[]
  assistantConversations    AssistantConversation[]
  memberRequests            MemberRequest[]
  requestVotes              RequestVote[]
  contentPlans              ContentPlan[]
  bookingReservations       BookingReservation[]
  stories                   Story[]
  tips                      Tip[]
  notifications             Notification[]             @relation("NotificationRecipient")
  notificationsTriggered    Notification[]             @relation("NotificationActor")
  pushSubscriptions         PushSubscription[]
  newsletterDeliveries      NewsletterDelivery[]
  newsletterConsents        NewsletterConsent[]
  newsletterConsentEvents   NewsletterConsentEvent[]
  emailSuppressions         EmailSuppression[]
  pendingCreatorCheckouts   PendingCreatorCheckout[]
  legalAcceptances          LegalAcceptance[]
  pollVotes                 PollVote[]
}

/// Versioned evidence that a user accepted a contract document or confirmed
/// receipt of a privacy notice. Marketing consent is deliberately stored in a
/// separate model because it must remain optional and independently revocable.
model LegalAcceptance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   String
  version    String
  source     String
  acceptedAt DateTime @default(now())

  @@unique([userId, document, version])
  @@index([document, version, acceptedAt])
}

// ----------------------------------------------------------------------------
// Tenant (a creator community)
// ----------------------------------------------------------------------------
model Tenant {
  id                     String    @id @default(cuid())
  name                   String    @unique
  slug                   String    @unique
  subdomain              String?   @unique
  customDomain           String?   @unique
  /// Gesetzt, sobald der DNS-Nachweis (CNAME/TXT) erbracht wurde. Nur
  /// verifizierte Domains werden vom Proxy aufgelöst.
  customDomainVerifiedAt DateTime?
  tagline                String?
  description            String?
  logoUrl                String?
  primaryColor           String    @default("#6d28d9")
  accentColor            String    @default("#ec4899")
  // Discover category key (see lib/categories.ts).
  category               String?

  // Community page builder config (sections order/visibility, custom nav, header
  // options). Null = platform defaults. See lib/layout.ts.
  layout Json?

  platformFeePercent Float        @default(5)
  /// Referral-Programm: Provision (in %) auf bezahlte Käufe geworbener
  /// Mitglieder. 0 = Programm ohne Geld-Provision (nur Punkte via Gamification).
  referralPercent    Float        @default(0)
  stripeAccountId    String?
  /// SUSPENDED/DELETING Tenants sind weder öffentlich noch im Creator-
  /// Dashboard erreichbar. Billing-/Cleanup-Webhooks dürfen weiterarbeiten.
  status             TenantStatus @default(ACTIVE)

  ownerId String
  owner   User   @relation("TenantOwner", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships               Membership[]
  tiers                     MembershipTier[]
  spaces                    Space[]
  posts                     Post[]
  comments                  Comment[]
  reactions                 Reaction[]
  courses                   Course[]
  lessons                   Lesson[]
  lessonProgress            LessonProgress[]
  events                    Event[]
  eventRsvps                EventRsvp[]
  products                  Product[]
  orders                    Order[]
  subscriptions             Subscription[]
  entitlements              Entitlement[]
  campaigns                 NewsletterCampaign[]
  segments                  Segment[]
  emailEvents               EmailEvent[]
  rules                     GamificationRule[]
  pointsLedger              PointsLedger[]
  badges                    Badge[]
  badgeAwards               BadgeAward[]
  levels                    Level[]
  memberStats               MemberStats[]
  storageObjects            StorageObject[]
  storageUploadReservations StorageUploadReservation[]
  mediaFolders              MediaFolder[]
  aiChunks                  AiContextChunk[]
  recommendations           Recommendation[]
  liveSessions              LiveSession[]
  liveMessages              LiveChatMessage[]
  articles                  KnowledgeArticle[]
  auditLogs                 AuditLog[]
  chatMessages              ChatMessage[]
  conversations             Conversation[]
  conversationMembers       ConversationMember[]
  assistantConversations    AssistantConversation[]
  memberRequests            MemberRequest[]
  requestVotes              RequestVote[]
  contentPlans              ContentPlan[]
  contentPlanMedia          ContentPlanMedia[]
  bookingSlots              BookingSlot[]
  bookingReservations       BookingReservation[]
  stories                   Story[]
  tips                      Tip[]
  aiCreditWallet            AiCreditWallet?
  aiUsageEvents             AiUsageEvent[]
  aiCreditPurchases         AiCreditPurchase[]
  aiCreditReservations      AiCreditReservation[]
  notifications             Notification[]
  apiKeys                   ApiKey[]
  webhookEndpoints          WebhookEndpoint[]
  webhookDeliveries         WebhookDelivery[]
  referralConversions       ReferralConversion[]
  moderationFlags           ModerationFlag[]
  automationSteps           AutomationStep[]
  automationDeliveries      AutomationDelivery[]
  newsletterDeliveries      NewsletterDelivery[]
  newsletterConsents        NewsletterConsent[]
  newsletterConsentEvents   NewsletterConsentEvent[]
  emailSuppressions         EmailSuppression[]
  pendingCreatorCheckouts   PendingCreatorCheckout[]
  pollVotes                 PollVote[]

  @@index([slug])
  @@index([category])
  @@index([status])
}

// ----------------------------------------------------------------------------
// Membership: user-in-tenant relationship
// ----------------------------------------------------------------------------
model Membership {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role            @default(MEMBER)
  status       MemberStatus    @default(ACTIVE)
  tierId       String?
  tier         MembershipTier? @relation(fields: [tierId], references: [id])
  bio          String?
  /// Persönlicher Einladungs-Code (Referral-Programm), lazily erzeugt.
  referralCode String?
  /// userId des werbenden Mitglieds (innerhalb desselben Tenants).
  referredById String?
  joinedAt     DateTime        @default(now())

  @@unique([tenantId, userId])
  @@unique([tenantId, referralCode])
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([userId, status, role])
  @@index([tenantId, referredById])
  @@index([userId])
}

model MembershipTier {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  description     String?
  // Card cover image on the join page.
  coverUrl        String?
  // "Vom Creator empfohlen" highlight on the join page (max. one per tenant).
  isRecommended   Boolean         @default(false)
  priceCents      Int             @default(0)
  currency        String          @default("eur")
  interval        BillingInterval @default(FREE)
  stripeProductId String?
  stripePriceId   String?
  /// Explizites Apple-IAP-Produkt (StoreKit) für diese Stufe; null = Preis-Pool-Fallback.
  appleProductId  String?
  entitlementKey  String // e.g. "tier:premium" — granted to members on this tier
  isDefault       Boolean         @default(false)
  isPublic        Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())

  memberships   Membership[]
  subscriptions Subscription[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// ----------------------------------------------------------------------------
// Spaces & content
// ----------------------------------------------------------------------------
model Space {
  id                     String     @id @default(cuid())
  tenantId               String
  tenant                 Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                   String
  slug                   String
  type                   SpaceType
  description            String?
  icon                   String?
  visibility             Visibility @default(MEMBERS)
  // Paywall: optional minimum tier required (by entitlement key)
  requiredEntitlementKey String?
  sortOrder              Int        @default(0)
  isArchived             Boolean    @default(false)
  // Per-space display settings (sorting, pagination, layout, …) as JSON.
  settings               Json?
  createdAt              DateTime   @default(now())

  posts          Post[]
  courses        Course[]
  events         Event[]
  products       Product[]
  articles       KnowledgeArticle[]
  liveSessions   LiveSession[]
  mediaPackages  MediaPackage[]
  chatMessages   ChatMessage[]
  memberRequests MemberRequest[]
  bookingSlots   BookingSlot[]
  stories        Story[]
  tips           Tip[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

enum RequestStatus {
  OPEN
  ACCEPTED
  PRICED
  FULFILLED
  DECLINED
}

// REQUESTS space: members submit wishes / custom requests; the creator can
// accept, decline, or price them. Priced requests are paid via Stripe.
model MemberRequest {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId        String
  space          Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  requesterId    String
  requester      User          @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  title          String
  body           String        @default("")
  status         RequestStatus @default(OPEN)
  priceCents     Int           @default(0)
  currency       String        @default("eur")
  entitlementKey String? // "request:{id}" — granted on payment
  staffNote      String?
  /// Denormalized up/down vote sum, kept in sync by voteRequestAction. Orders
  /// the public wishes board (most-voted first).
  score          Int           @default(0)
  votes          RequestVote[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([tenantId, spaceId])
  @@index([tenantId, requesterId])
  @@index([tenantId, spaceId, score])
}

/// Reddit-style up/down vote on a member wish. value is +1 (up) or -1 (down).
model RequestVote {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestId String
  request   MemberRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int
  createdAt DateTime      @default(now())

  @@unique([requestId, userId])
  @@index([tenantId, requestId])
}

enum ContentPlanType {
  POST
  VIDEO
  STREAM
  STORY
  NEWSLETTER
  EVENT
  PRODUCT_DROP
  OTHER
}

enum ContentPlanStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Standalone content planner: a creator schedules posts, videos, streams, etc.
/// Independent from Post.scheduledAt / Story.publishAt (linking comes later).
model ContentPlan {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        ContentPlanType    @default(POST)
  status      ContentPlanStatus  @default(DRAFT)
  scheduledAt DateTime?
  completedAt DateTime?
  /// Optional target space (soft reference, validated on write).
  spaceId     String?
  /// Checklist as JSON: [{ id, text, done }].
  checklist   Json?
  /// Last AI suggestion shown as an info box.
  aiNotes     String?
  createdById String
  createdBy   User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  media       ContentPlanMedia[]

  @@index([tenantId, status, scheduledAt])
  @@index([tenantId, scheduledAt])
}

/// A media attachment on a content plan. Stores a URL snapshot so the plan
/// survives deletion of the underlying StorageObject.
model ContentPlanMedia {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId          String
  plan            ContentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  storageObjectId String?
  url             String
  contentType     String?
  caption         String?
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())

  @@index([tenantId, planId])
  @@index([planId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// BOOKING space: bookable 1:1 slots and their reservations.
model BookingSlot {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId     String
  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  hostId      String
  title       String
  startsAt    DateTime
  durationMin Int      @default(30)
  priceCents  Int      @default(0)
  currency    String   @default("eur")
  capacity    Int      @default(1)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  reservations BookingReservation[]

  @@index([tenantId, spaceId])
  @@index([tenantId, startsAt])
}

model BookingReservation {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slotId          String
  slot            BookingSlot       @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          ReservationStatus @default(PENDING)
  stripeSessionId String?           @unique
  createdAt       DateTime          @default(now())

  @@index([tenantId, slotId])
  @@index([tenantId, userId])
}

// STORIES space: ephemeral posts that expire (typically after 24h).
model Story {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  imageUrl  String?
  videoUrl  String?
  caption   String?
  /// Go-live time. `publishAt > now` = scheduled; `publishAt <= now < expiresAt`
  /// = active; `expiresAt <= now` = archived. State is purely time-derived.
  publishAt DateTime @default(now())
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tenantId, spaceId])
  @@index([tenantId, expiresAt])
  @@index([tenantId, publishAt])
}

enum TipStatus {
  PENDING
  PAID
  REFUNDED
}

// TIPS space: tips / shoutouts, optionally toward a goal.
model Tip {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId     String
  space       Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents Int
  currency    String    @default("eur")
  message     String?
  isPublic    Boolean   @default(true)
  status      TipStatus @default(PENDING)
  createdAt   DateTime  @default(now())

  @@index([tenantId, spaceId])
}

// Gallery: a folder/album of media (images + videos), free or for sale.
model MediaPackage {
  id             String    @id @default(cuid())
  tenantId       String
  spaceId        String
  space          Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title          String
  slug           String
  description    String?
  coverUrl       String?
  priceCents     Int       @default(0) // 0 = free to view
  currency       String    @default("eur")
  entitlementKey String // "media:{slug}" — granted on purchase
  isPublished    Boolean   @default(true)
  // Optional campaign end: after this the package is hidden from the community.
  availableUntil DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items MediaItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, spaceId])
}

model MediaItem {
  id             String       @id @default(cuid())
  tenantId       String
  packageId      String
  package        MediaPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  type           String // IMAGE | VIDEO
  url            String
  caption        String?
  sortOrder      Int          @default(0)
  // Per-item pay-per-view inside a package. 0 = inherits package access.
  priceCents     Int          @default(0)
  entitlementKey String? // "media-item:{id}" — granted on single-item purchase
  teaserUrl      String? // blurred/low-res preview shown to non-buyers
  isPreview      Boolean      @default(false) // free sample even in a paid package
  createdAt      DateTime     @default(now())

  @@index([tenantId, packageId])
}

model Post {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId        String
  space          Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  authorId       String
  author         User      @relation(fields: [authorId], references: [id])
  title          String?
  body           String    @default("") // plain text (search / excerpts)
  bodyHtml       String? // rich HTML for blog posts (WYSIWYG)
  imageUrl       String? // gallery image / post attachment
  videoUrl       String? // video post
  isPinned       Boolean   @default(false)
  isPublished    Boolean   @default(true)
  publishedAt    DateTime  @default(now())
  // Scheduled go-live: when set and in the future the post stays hidden until a
  // cron flips isPublished. Public queries additionally require publishedAt <= now.
  scheduledAt    DateTime?
  // Pay-per-view / pay-per-post: 0 = free. When > 0 the body/media are gated
  // behind `entitlementKey` (video:{id} for VIDEOS spaces, post:{id} otherwise).
  priceCents     Int       @default(0)
  currency       String    @default("eur")
  entitlementKey String? // set on create when priceCents > 0
  teaserUrl      String? // public teaser image/poster shown to non-buyers
  // Poll attached to this post: pollQuestion set => the post has a poll,
  // pollOptions holds the option labels, votes live in PollVote.
  pollQuestion   String?
  pollOptions    String[]  @default([])
  pollMultiple   Boolean   @default(false)
  // Per-post settings authored in the composer's "Settings" panel.
  customSlug        String?
  customHtml        String?
  hideComments      Boolean  @default(false)
  closeComments     Boolean  @default(false)
  hideLikes         Boolean  @default(false)
  hideMetaInfo      Boolean  @default(false)
  hideFromFeatured  Boolean  @default(false)
  disableTruncation Boolean  @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  comments  Comment[]
  reactions Reaction[]
  pollVotes PollVote[]

  @@index([tenantId, spaceId])
  @@index([tenantId, createdAt])
  @@index([tenantId, authorId])
  @@unique([tenantId, customSlug])
}

model Comment {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  body      String
  parentId  String?
  parent    Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentThread")
  createdAt DateTime  @default(now())

  reactions Reaction[]

  @@index([tenantId, postId])
  @@index([tenantId, authorId])
  @@index([parentId])
}

model Reaction {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  type      String   @default("LIKE")
  createdAt DateTime @default(now())

  @@unique([userId, postId, type])
  @@unique([userId, commentId, type])
  @@index([postId, type])
  @@index([commentId, type])
  @@index([tenantId])
}

// ----------------------------------------------------------------------------
// Courses & lessons
// ----------------------------------------------------------------------------
model Course {
  id                     String  @id @default(cuid())
  tenantId               String
  tenant                 Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId                String
  space                  Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title                  String
  slug                   String
  description            String?
  coverUrl               String?
  isPublished            Boolean @default(false)
  requiredEntitlementKey String?

  // Delivery format: "ONLINE" (video / live stream) or "OFFLINE" (in person).
  format    String    @default("ONLINE")
  videoUrl  String? // online: recorded video URL
  streamUrl String? // online: live stream / meeting URL
  location  String? // offline: venue name
  address   String? // offline: full address
  startsAt  DateTime? // offline: date & time
  capacity  Int? // offline: number of seats

  createdAt DateTime @default(now())

  lessons Lesson[]

  @@unique([tenantId, slug])
  @@index([tenantId, spaceId])
}

model Lesson {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title         String
  slug          String
  content       String   @default("")
  videoUrl      String?
  durationSec   Int      @default(0)
  sortOrder     Int      @default(0)
  isPreview     Boolean  @default(false)
  /// Drip-Content: erst N Tage nach Community-Beitritt freigeschaltet.
  /// Null/0 = sofort verfügbar.
  dripAfterDays Int?
  createdAt     DateTime @default(now())

  progress LessonProgress[]

  @@unique([courseId, slug])
  @@index([tenantId, courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([lessonId, userId])
  @@index([tenantId, userId])
}

// ----------------------------------------------------------------------------
// Events
// ----------------------------------------------------------------------------
model Event {
  id                     String    @id @default(cuid())
  tenantId               String
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId                String
  space                  Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title                  String
  slug                   String
  description            String?
  coverUrl               String?
  startsAt               DateTime
  endsAt                 DateTime?
  location               String?
  isOnline               Boolean   @default(true)
  meetingUrl             String?
  capacity               Int?
  requiredEntitlementKey String?
  createdAt              DateTime  @default(now())

  rsvps EventRsvp[]

  @@unique([tenantId, slug])
  @@index([tenantId, startsAt])
}

model EventRsvp {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RsvpStatus @default(GOING)
  createdAt DateTime   @default(now())

  @@unique([eventId, userId])
  @@index([tenantId, eventId])
}

// ----------------------------------------------------------------------------
// Commerce
// ----------------------------------------------------------------------------
model Product {
  id                   String      @id @default(cuid())
  tenantId             String
  tenant               Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId              String?
  space                Space?      @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  name                 String
  slug                 String
  description          String?
  // Primary cover image (kept in sync with images[0] for list/tile displays).
  coverUrl             String?
  // Full image gallery (cover first). Empty = no images.
  images               String[]    @default([])
  priceCents           Int         @default(0)
  currency             String      @default("eur")
  type                 ProductType @default(DIGITAL)
  stripeProductId      String?
  stripePriceId        String?
  /// Explizites Apple-IAP-Produkt (StoreKit); PHYSICAL-Produkte sind nie per IAP kaufbar.
  appleProductId       String?
  downloadUrl          String?
  grantsEntitlementKey String? // entitlement granted on purchase
  isPublished          Boolean     @default(true)

  // Physical products: shipping & inventory
  requiresShipping Boolean @default(false)
  freeShipping     Boolean @default(false)
  shippingCents    Int     @default(0)
  stock            Int? // null = unbegrenzt

  createdAt DateTime @default(now())

  orders Order[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Order {
  id                              String      @id @default(cuid())
  tenantId                        String
  tenant                          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId                          String
  user                            User        @relation(fields: [userId], references: [id])
  productId                       String?
  product                         Product?    @relation(fields: [productId], references: [id])
  description                     String
  amountCents                     Int
  currency                        String      @default("eur")
  platformFeeCents                Int         @default(0)
  shippingCents                   Int         @default(0)
  status                          OrderStatus @default(PENDING)
  // Shipping address captured at checkout (for physical products).
  shippingDetails                 Json?
  fulfilled                       Boolean     @default(false)
  stripeSessionId                 String?     @unique
  stripePaymentIntentId           String?
  // Limited physical inventory is reserved before an external checkout is
  // created. These timestamps make release/fulfilment idempotent across
  // duplicate submits, Stripe retries and expired Checkout Sessions.
  inventoryReservedAt             DateTime?
  inventoryReservationExpiresAt   DateTime?
  inventoryReleasedAt             DateTime?
  /// Apple-IAP: transactionId der signierten StoreKit-Transaktion (Idempotenz).
  appleTransactionId              String?     @unique
  // Snapshot used to revoke paid access even if the product/package changes.
  grantedEntitlementKey           String?
  /// Evidence for immediate delivery of paid digital content. Null for
  /// physical goods and legacy orders created before consent capture.
  immediatePerformanceConsentedAt DateTime?
  withdrawalLossAcknowledgedAt    DateTime?
  legalTermsVersion               String?
  refundedAt                      DateTime?
  createdAt                       DateTime    @default(now())

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, stripePaymentIntentId])
  @@index([tenantId, productId, userId, status])
  @@index([status, inventoryReservationExpiresAt])
}

model Subscription {
  id                              String             @id @default(cuid())
  tenantId                        String
  tenant                          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId                          String
  user                            User               @relation(fields: [userId], references: [id])
  tierId                          String
  tier                            MembershipTier     @relation(fields: [tierId], references: [id])
  status                          SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId            String?            @unique
  /// Apple-IAP: originalTransactionId des Auto-Renewable-Abos (Idempotenz + Notification-Sync).
  appleOriginalTransactionId      String?            @unique
  currentPeriodEnd                DateTime?
  cancelAtPeriodEnd               Boolean            @default(false)
  /// Evidence for immediate access during the consumer withdrawal period.
  immediatePerformanceConsentedAt DateTime?
  withdrawalLossAcknowledgedAt    DateTime?
  legalTermsVersion               String?
  createdAt                       DateTime           @default(now())
  /// Für Analytics (z. B. Kündigungen der letzten 30 Tage).
  updatedAt                       DateTime           @default(now()) @updatedAt

  @@index([tenantId, userId])
}

model Entitlement {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String // e.g. "tier:premium", "product:masterclass"
  source    EntitlementSource @default(MANUAL)
  sourceId  String?
  grantedAt DateTime          @default(now())
  expiresAt DateTime?

  @@unique([tenantId, userId, key])
  @@index([tenantId, key])
  @@index([tenantId, userId])
}

// ----------------------------------------------------------------------------
// Newsletter
// ----------------------------------------------------------------------------
model NewsletterCampaign {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subject        String
  body           String // markdown / html
  status         CampaignStatus @default(DRAFT)
  segmentId      String?
  segment        Segment?       @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int            @default(0)
  createdById    String
  createdBy      User           @relation(fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())

  emailEvents EmailEvent[]
  deliveries  NewsletterDelivery[]

  @@index([tenantId, status])
}

model Segment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // JSON rules e.g. { "tierSlug": "premium", "minPoints": 100, "activeSinceDays": 30 }
  rules       Json     @default("{}")
  createdAt   DateTime @default(now())

  campaigns NewsletterCampaign[]

  @@index([tenantId])
}

model EmailEvent {
  id         String              @id @default(cuid())
  tenantId   String
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId String?
  campaign   NewsletterCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  userId     String?
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  email      String
  type       EmailEventType      @default(QUEUED)
  /// Stable key for retry-safe terminal delivery events.
  dedupeKey  String?             @unique
  createdAt  DateTime            @default(now())

  @@index([tenantId, campaignId])
}

model NewsletterDelivery {
  id                String                   @id @default(cuid())
  tenantId          String
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId        String
  campaign          NewsletterCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId            String
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientEmail    String
  subject           String
  html              String
  status            NewsletterDeliveryStatus @default(PENDING)
  attempts          Int                      @default(0)
  nextAttemptAt     DateTime                 @default(now())
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  leaseUntil        DateTime?
  providerMessageId String?
  /// Public bearer URL used only for the safe unsubscribe operation. It is
  /// embedded into the immutable email snapshot and the RFC 8058 headers.
  unsubscribeUrl    String?
  error             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([campaignId, userId])
  @@index([tenantId, campaignId])
  @@index([status, nextAttemptAt])
}

/// Current per-community newsletter preference. Rows are created only after
/// an explicit opt-in or withdrawal; the migration deliberately creates no
/// rows for existing members.
model NewsletterConsent {
  id              String                  @id @default(cuid())
  tenantId        String
  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  email           String
  status          NewsletterConsentStatus
  optedInAt       DateTime?
  optedInSource   String?
  withdrawnAt     DateTime?
  withdrawnSource String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  events NewsletterConsentEvent[]

  @@unique([tenantId, userId])
  @@index([tenantId, status, updatedAt])
  @@index([userId])
}

/// Append-only evidence trail for opt-ins and withdrawals. Source values are
/// stable technical identifiers, never free-form legal conclusions.
model NewsletterConsentEvent {
  id        String                     @id @default(cuid())
  tenantId  String
  tenant    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consentId String
  consent   NewsletterConsent          @relation(fields: [consentId], references: [id], onDelete: Cascade)
  userId    String
  user      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  type      NewsletterConsentEventType
  source    String
  createdAt DateTime                   @default(now())

  @@index([tenantId, userId, createdAt])
  @@index([consentId, createdAt])
}

/// Active suppressions are never bypassed by segment rules. A new explicit
/// opt-in may lift UNSUBSCRIBED, but bounce/complaint suppressions require a
/// separate operational review.
model EmailSuppression {
  id           String                 @id @default(cuid())
  tenantId     String
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  email        String
  reason       EmailSuppressionReason
  source       String
  suppressedAt DateTime               @default(now())
  liftedAt     DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([tenantId, email, reason])
  @@index([tenantId, email, liftedAt])
  @@index([userId])
}

/// Global, privileged inbox used to deduplicate signed Resend webhook events.
/// It contains only delivery metadata required for reliable processing.
model EmailWebhookEvent {
  id                String    @id
  type              String
  providerMessageId String?
  processedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([providerMessageId])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// Global background-job heartbeat (privileged worker only)
// ----------------------------------------------------------------------------
model CronJobHeartbeat {
  /// Stable route/job name, e.g. "newsletters" or "inventory".
  job             String        @id
  status          CronJobStatus @default(IDLE)
  lastStartedAt   DateTime?
  lastSucceededAt DateTime?
  lastFailedAt    DateTime?
  lastDurationMs  Int?
  /// Numeric, job-specific counters from the most recent completed run.
  lastCounters    Json          @default("{}")
  /// Sanitized message only; stack traces, URLs and credentials are excluded.
  lastError       String?
  totalRuns       Int           @default(0)
  totalSucceeded  Int           @default(0)
  totalFailed     Int           @default(0)
  /// Compare-and-set token and lease prevent overlapping executions per job.
  runToken        String?
  leaseUntil      DateTime?
  updatedAt       DateTime      @updatedAt

  @@index([status, updatedAt])
}

// Durable platform lifecycle jobs intentionally have no Tenant/User foreign
// keys: they must survive deletion of their target and remain retryable.
model DataDeletionJob {
  id                 String             @id @default(cuid())
  scope              DataDeletionScope
  targetId           String
  requestedById      String?
  targetLabel        String?
  status             DataDeletionStatus @default(PENDING)
  phase              String             @default("BILLING")
  attempts           Int                @default(0)
  nextAttemptAt      DateTime           @default(now())
  leaseUntil         DateTime?
  lastError          String?
  counters           Json               @default("{}")
  objectScanCursor   String?
  objectScanComplete Boolean            @default(false)
  completedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  objectTasks ObjectDeletionTask[]

  @@unique([scope, targetId])
  @@index([status, nextAttemptAt])
}

model ObjectDeletionTask {
  id            String               @id @default(cuid())
  jobId         String?
  job           DataDeletionJob?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  tenantId      String?
  key           String               @unique
  reason        String
  status        ObjectDeletionStatus @default(PENDING)
  attempts      Int                  @default(0)
  nextAttemptAt DateTime             @default(now())
  leaseUntil    DateTime?
  lastError     String?
  completedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([jobId, status])
  @@index([status, nextAttemptAt])
  @@index([tenantId, status])
}

model StorageReconciliationState {
  tenantId          String    @id
  continuationToken String?
  scanStartedAt     DateTime?
  lastCompletedAt   DateTime?
  lastScanned       Int       @default(0)
  lastOrphans       Int       @default(0)
  updatedAt         DateTime  @updatedAt
}

/// Legally required financial snapshots survive tenant/user erasure without
/// retaining live account relations. Subject identifiers are one-way hashes.
model BillingRetentionRecord {
  id              String   @id @default(cuid())
  source          String
  sourceId        String
  tenantScopeHash String
  subjectHash     String?
  payload         Json
  retainUntil     DateTime
  createdAt       DateTime @default(now())

  @@unique([source, sourceId])
  @@index([tenantScopeHash, retainUntil])
  @@index([retainUntil])
}

// ----------------------------------------------------------------------------
// Gamification
// ----------------------------------------------------------------------------
model GamificationRule {
  id        String              @id @default(cuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  trigger   GamificationTrigger
  points    Int                 @default(10)
  isActive  Boolean             @default(true)
  maxPerDay Int?
  createdAt DateTime            @default(now())

  ledger PointsLedger[]

  @@index([tenantId, trigger])
}

model PointsLedger {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  points    Int
  reason    String
  ruleId    String?
  rule      GamificationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  refType   String?
  refId     String?
  // Stable idempotency key for retryable actions such as Stripe fulfillment.
  dedupeKey String?           @unique
  createdAt DateTime          @default(now())

  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@index([tenantId, userId, ruleId, createdAt])
}

model Badge {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  iconUrl     String?
  // JSON criteria e.g. { "type": "points", "threshold": 100 } | { "type": "posts", "threshold": 10 }
  criteria    Json     @default("{}")
  createdAt   DateTime @default(now())

  awards BadgeAward[]

  @@index([tenantId])
}

model BadgeAward {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([badgeId, userId])
  @@index([tenantId, userId])
}

model Level {
  id        String @id @default(cuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  minPoints Int    @default(0)
  sortOrder Int    @default(0)

  @@index([tenantId, minPoints])
}

model MemberStats {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  points       Int       @default(0)
  levelName    String?
  streakDays   Int       @default(0)
  lastActiveOn DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId, points])
}

// ----------------------------------------------------------------------------
// Storage / media
// ----------------------------------------------------------------------------
model MediaFolder {
  id        String          @id @default(cuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  /// Folder accent color as a hex string (e.g. "#C2410C").
  color     String          @default("#C2410C")
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  objects   StorageObject[]

  @@index([tenantId])
}

model StorageObject {
  id                     String            @id @default(cuid())
  tenantId               String
  tenant                 Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId                String?
  owner                  User?             @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  key                    String
  url                    String
  purpose                String            @default("upload")
  contentType            String?
  sizeBytes              Int               @default(0)
  visibility             StorageVisibility @default(MEMBERS)
  requiredEntitlementKey String?
  /// Optional library display name (S3 key stays unchanged).
  displayName            String?
  /// Optional folder in the creator media library.
  folderId               String?
  folder                 MediaFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt              DateTime          @default(now())

  @@index([tenantId])
  @@index([folderId])
}

/// Short-lived, quota-counted authorization for a direct browser-to-S3 PUT.
/// The corresponding StorageObject becomes visible only after size, checksum,
/// magic bytes and malware policy have been verified server-side.
model StorageUploadReservation {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  key            String              @unique
  purpose        String
  contentType    String
  sizeBytes      Int
  checksumSha256 String
  visibility     StorageVisibility
  status         StorageUploadStatus @default(RESERVED)
  expiresAt      DateTime
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([tenantId, status, expiresAt])
  @@index([ownerId, createdAt])
}

// ----------------------------------------------------------------------------
// AI context & recommendations (tenant-isolated)
// ----------------------------------------------------------------------------
model AiContextChunk {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceType String // POST | PRODUCT | LESSON | EVENT | ARTICLE
  sourceId   String
  title      String?
  content    String
  keywords   String   @default("") // space-separated, for offline keyword recall
  embedding  Json? // float[] when OpenAI key configured, else null
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, sourceType, sourceId])
  @@index([tenantId, sourceType])
}

model Recommendation {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refType   String // PRODUCT | POST | LESSON | EVENT
  refId     String
  score     Float    @default(0)
  reason    String?
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
}

// ----------------------------------------------------------------------------
// Live streaming
// ----------------------------------------------------------------------------
model LiveSession {
  id                     String     @id @default(cuid())
  tenantId               String
  tenant                 Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId                String?
  space                  Space?     @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  title                  String
  status                 LiveStatus @default(SCHEDULED)
  roomName               String     @unique
  hostId                 String
  streamUrl              String?
  replayUrl              String?
  requiredEntitlementKey String?
  startsAt               DateTime?
  endedAt                DateTime?
  createdAt              DateTime   @default(now())

  messages LiveChatMessage[]

  @@index([tenantId, status])
}

model LiveChatMessage {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId String
  session   LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime    @default(now())

  @@index([tenantId, sessionId])
}

// ----------------------------------------------------------------------------
// Knowledge base
// ----------------------------------------------------------------------------
model KnowledgeArticle {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaceId     String
  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  body        String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, spaceId])
}

// ----------------------------------------------------------------------------
// Audit log
// ----------------------------------------------------------------------------
model AuditLog {
  id              String    @id @default(cuid())
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUserId     String?
  action          String
  targetType      String?
  targetId        String?
  metadata        Json      @default("{}")
  /// Audit evidence is detached from deleted tenants but retained for the
  /// documented legal/security window under a pseudonymous scope hash.
  tenantScopeHash String?
  retentionUntil  DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantScopeHash, retentionUntil])
}

// ----------------------------------------------------------------------------
// Chat & Direct Messages
// ----------------------------------------------------------------------------

// A 1:1 direct-message thread between two community members. Group chats reuse
// the Space model (type = CHAT), so a ChatMessage belongs to exactly one of
// `spaceId` (group) or `conversationId` (direct).
model Conversation {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // "DIRECT" (1:1 DM) or "GROUP" (creator-run room). Plain string, not a Prisma
  // enum, so it can evolve without a client regeneration.
  kind          String   @default("DIRECT")
  // Group chats only: display name, avatar tint and access gate.
  title         String?
  avatarColor   String?
  // null = all members · "__paid__" = paying members · "tier:<slug>" = a level.
  accessKey     String?
  createdById   String?
  createdAt     DateTime @default(now())
  // Denormalised for cheap "sort by most recent activity" in the inbox.
  lastMessageAt DateTime @default(now())

  members  ConversationMember[]
  messages ChatMessage[]

  @@index([tenantId, kind, lastMessageAt])
}

model ConversationMember {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Read receipts / unread badges.
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([tenantId, userId])
}

model ChatMessage {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Group chat target (Space of type CHAT) …
  spaceId        String?
  space          Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  // … or direct-message thread. Exactly one is set.
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime      @default(now())

  @@index([tenantId, spaceId, createdAt])
  @@index([tenantId, conversationId, createdAt])
}

// ----------------------------------------------------------------------------
// AI Assistant (dashboard) — persisted conversations with tool use.
// ----------------------------------------------------------------------------
model AssistantConversation {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "CHAT" (text assistant) or "IMAGE" (image generation). Kept as a plain
  // string so it can evolve without a client regeneration.
  kind      String   @default("CHAT")
  title     String   @default("Neuer Chat")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AssistantMessage[]

  @@index([tenantId, userId, kind, updatedAt])
}

model AssistantMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String
  createdAt      DateTime              @default(now())

  @@index([conversationId, createdAt])
}

// ----------------------------------------------------------------------------
// AI credits — one wallet per tenant. `includedRemaining` is the plan's monthly
// allowance (resets each period); `purchasedRemaining` are bought top-ups that
// roll over. Consumption draws from the included allowance first.
// ----------------------------------------------------------------------------
model AiCreditWallet {
  id                        String              @id @default(cuid())
  tenantId                  String              @unique
  tenant                    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                      CreatorPlan         @default(FREE)
  monthlyCredits            Int                 @default(500)
  includedRemaining         Int                 @default(500)
  purchasedRemaining        Int                 @default(0)
  periodStart               DateTime            @default(now())
  periodEnd                 DateTime
  stripeCustomerId          String?
  stripeSubscriptionId      String?             @unique
  // Business idempotency key for payment-driven monthly allowance refills.
  lastPaidStripeInvoiceId   String?             @unique
  creatorSubscriptionStatus SubscriptionStatus?
  planCancelAtPeriodEnd     Boolean             @default(false)
  planCurrentPeriodEnd      DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
}

// Durable boundary between a creator's plan choice and Stripe Checkout. The
// row exists before Stripe can accept money, so destructive tenant operations
// can see open sessions even before a subscription id exists on the wallet.
model PendingCreatorCheckout {
  id                   String                @id @default(cuid())
  tenantId             String
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId               String
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 CreatorPlan
  status               CreatorCheckoutStatus @default(CREATING)
  stripeSessionId      String?               @unique
  stripeSubscriptionId String?               @unique
  expiresAt            DateTime
  completedAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([tenantId, status])
  @@index([status, expiresAt])
}

// Per-call usage ledger (metered from Gemini token counts).
model AiUsageEvent {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String?
  conversationId String?
  kind           String   @default("assistant_message")
  promptTokens   Int      @default(0)
  outputTokens   Int      @default(0)
  totalTokens    Int      @default(0)
  credits        Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
}

// ----------------------------------------------------------------------------
// Platform help center — admin-managed, tenant-neutral, public at /hilfe.
// ----------------------------------------------------------------------------
model HelpCategory {
  id          String   @id @default(cuid())
  locale      String   @default("de")
  title       String
  slug        String
  description String?
  icon        String   @default("knowledge")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  articles HelpArticle[]

  @@unique([locale, slug])
  @@index([sortOrder])
  @@index([locale, sortOrder])
}

model HelpArticle {
  id          String       @id @default(cuid())
  categoryId  String
  category    HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  question    String
  answer      String
  sortOrder   Int          @default(0)
  isPublished Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([categoryId, sortOrder])
}

// Credit top-up purchases (packs).
model AiCreditPurchase {
  id                    String    @id @default(cuid())
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId                String?
  packId                String?
  credits               Int
  priceCents            Int
  currency              String    @default("eur")
  status                String    @default("COMPLETED")
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?
  refundedAt            DateTime?
  createdAt             DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, stripePaymentIntentId])
}

// A one-credit lease acquired before an external AI request. Settlement and
// release are database-atomic so concurrent requests cannot overspend a wallet.
model AiCreditReservation {
  id              String                    @id
  tenantId        String
  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String?
  conversationId  String?
  kind            String                    @default("assistant_message")
  source          AiCreditSource
  reservedCredits Int                       @default(1)
  chargedCredits  Int?
  promptTokens    Int                       @default(0)
  outputTokens    Int                       @default(0)
  totalTokens     Int                       @default(0)
  status          AiCreditReservationStatus @default(RESERVED)
  expiresAt       DateTime
  settledAt       DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([tenantId, status, expiresAt])
  @@index([tenantId, createdAt])
}

// Durable inbox for Stripe events. This is platform-operational data rather
// than tenant content, so events can still be retried after a tenant was
// removed and events without tenant metadata can be diagnosed.
model StripeWebhookEvent {
  id          String              @id
  type        String
  objectId    String?
  tenantId    String?
  status      StripeWebhookStatus @default(PROCESSING)
  attempts    Int                 @default(1)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([tenantId, createdAt])
  @@index([status, updatedAt])
}

// ----------------------------------------------------------------------------
// In-App-Benachrichtigungen (pro Tenant, pro Empfänger)
// ----------------------------------------------------------------------------
enum NotificationType {
  POST_COMMENT // jemand hat deinen Beitrag kommentiert
  COMMENT_REPLY // jemand hat auf deinen Kommentar geantwortet
  REACTION // jemand hat auf deinen Beitrag reagiert
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Empfänger der Benachrichtigung.
  userId    String
  user      User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  /// Auslöser (z. B. der Kommentator). Null, wenn das Konto gelöscht wurde.
  actorId   String?
  actor     User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  type      NotificationType
  message   String
  /// Ziel-Link innerhalb der Community (z. B. der kommentierte Beitrag).
  href      String
  refType   String?
  refId     String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([tenantId, userId, readAt])
  @@index([tenantId, userId, createdAt])
}

// ----------------------------------------------------------------------------
// Öffentliche API (Keys) & ausgehende Webhooks
// ----------------------------------------------------------------------------
model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  /// Anzeige-Präfix (z. B. "aera_sk_3f9a…") — der volle Key wird nie gespeichert.
  prefix     String
  /// SHA-256-Hash des vollständigen Keys.
  keyHash    String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String
  /// Shared Secret für die HMAC-SHA256-Signatur (Header `Aera-Signature`).
  secret    String
  /// Abonnierte Event-Typen (z. B. "member.joined", "order.paid").
  events    String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([tenantId])
}

model WebhookDelivery {
  id            String                @id @default(cuid())
  tenantId      String
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpointId    String
  endpoint      WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  eventId       String
  event         String
  payload       Json
  /// HTTP-Status der Zustellung; null bei Netzwerkfehler.
  responseCode  Int?
  ok            Boolean               @default(false)
  error         String?
  status        WebhookDeliveryStatus @default(PENDING)
  attempts      Int                   @default(0)
  nextAttemptAt DateTime              @default(now())
  lastAttemptAt DateTime?
  deliveredAt   DateTime?
  leaseUntil    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([endpointId, eventId])
  @@index([tenantId, endpointId, createdAt])
  @@index([status, nextAttemptAt])
}

// ----------------------------------------------------------------------------
// Web-Push (global pro Nutzer, nicht tenant-gebunden)
// ----------------------------------------------------------------------------
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ----------------------------------------------------------------------------
// KI-Moderation (Auto-Flagging von Beiträgen/Kommentaren)
// ----------------------------------------------------------------------------
enum ModerationStatus {
  PENDING // wartet auf Entscheidung des Teams
  APPROVED // freigegeben (Fehlalarm)
  REMOVED // Inhalt entfernt
}

model ModerationFlag {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// "Post" | "Comment"
  refType      String
  refId        String
  authorId     String?
  /// z. B. "spam", "toxisch", "belaestigung"
  category     String
  /// Kurzbegründung des Klassifikators (KI oder Heuristik).
  reason       String
  /// "gemini" oder "heuristik"
  source       String           @default("heuristik")
  status       ModerationStatus @default(PENDING)
  /// Auszug des gemeldeten Inhalts (Anzeige ohne Join).
  excerpt      String
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())

  @@unique([tenantId, refType, refId])
  @@index([tenantId, status, createdAt])
}

// ----------------------------------------------------------------------------
// Onboarding-Automationen (zeitversetzte E-Mail-Serie nach Beitritt)
// ----------------------------------------------------------------------------
model AutomationStep {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Tage nach Beitritt (0 = sofort beim nächsten Lauf).
  dayOffset Int      @default(0)
  subject   String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  deliveries AutomationDelivery[]

  @@index([tenantId, dayOffset])
}

model AutomationDelivery {
  id                String                   @id @default(cuid())
  tenantId          String
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stepId            String
  step              AutomationStep           @relation(fields: [stepId], references: [id], onDelete: Cascade)
  userId            String
  recipientEmail    String
  subject           String
  html              String
  status            AutomationDeliveryStatus @default(PENDING)
  attempts          Int                      @default(0)
  nextAttemptAt     DateTime                 @default(now())
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  leaseUntil        DateTime?
  providerMessageId String?
  unsubscribeUrl    String?
  error             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  user              User                     @relation(fields: [userId], references: [id])

  @@unique([stepId, userId])
  @@index([tenantId, userId])
  @@index([status, nextAttemptAt])
}

// ----------------------------------------------------------------------------
// Referral-Programm
// ----------------------------------------------------------------------------
model ReferralConversion {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// userId des werbenden Mitglieds.
  referrerId      String
  /// userId des geworbenen Mitglieds.
  referredId      String
  /// "join" (Beitritt) oder "purchase" (bezahlter Kauf/Abo).
  kind            String
  /// Umsatzbasis in Cent (nur bei kind = "purchase").
  amountCents     Int       @default(0)
  /// Errechnete Provision in Cent (tenant.referralPercent zum Zeitpunkt).
  commissionCents Int       @default(0)
  refType         String?
  refId           String?
  reversedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@unique([tenantId, referredId, kind, refId])
  @@index([tenantId, referrerId])
  @@index([tenantId, createdAt])
}

model PollVote {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  optionIndex Int
  createdAt   DateTime @default(now())

  @@unique([postId, userId, optionIndex])
  @@index([tenantId])
  @@index([postId])
}
