# === Database (required) — Railway Postgres ===
# This is the privileged system connection used only when no tenant context is
# active (login, platform admin, Stripe inbox, discovery). Every tenant-scoped
# Prisma operation automatically executes `SET LOCAL ROLE aera_app` + the
# tenant GUC in one transaction, so PostgreSQL RLS is actually enforced.
# Locally use Railway's PUBLIC proxy URL; on Railway use the INTERNAL URL.
DATABASE_URL="postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway"
DATABASE_INTERNAL_URL="postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway"

# === Auth (required) ===
# 32+ char random secret used to sign session cookies (generate: openssl rand -base64 48)
AUTH_SECRET="change-me-to-a-long-random-string-please-32chars-min"

# Root domain used for multi-tenant subdomain resolution in production.
NEXT_PUBLIC_ROOT_DOMAIN="aera.so"
APP_URL="http://localhost:3000"

# === Stripe (optional – Commerce becomes live once set) ===
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Platform fee percentage (3-5% per plan)
AERA_PLATFORM_FEE_PERCENT="5"

# === Email / Newsletter (optional – sending becomes live once set) ===
RESEND_API_KEY=""
EMAIL_FROM="Aera <noreply@aera.so>"

# === AI (optional – upgrades recommendations from heuristic to embeddings) ===
# Primary provider: Google Gemini. GEMINI_MODEL powers text generation
# (recommendation reasons), GEMINI_EMBED_MODEL the semantic-search embeddings.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-flash-lite"
GEMINI_EMBED_MODEL="text-embedding-004"
# Image generation & editing for the assistant's "Bild" mode.
GEMINI_IMAGE_MODEL="gemini-3.1-flash-image"
# Fallback provider (used only if GEMINI_API_KEY is empty):
OPENAI_API_KEY=""

# === Streaming (optional) ===
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_URL=""

# === Storage: Railway S3-compatible bucket (Avatare, Uploads) ===
# Aus dem Railway-Bucket-Service übernehmen. Ohne diese Werte landen Uploads
# lokal in public/uploads (nur für Entwicklung).
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Buckets müssen privat bleiben. Uploads werden über den autorisierten
# /api/media-Proxy ausgeliefert; keine public-read ACL konfigurieren.
S3_ACL=""

# === Redis (optional – instanzübergreifende Rate-Limits, z. B. Railway Redis) ===
REDIS_URL=""

# === Web-Push (optional – aktiviert Push-Benachrichtigungen) ===
# Erzeugen mit: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# === Automations-Cron (Onboarding-E-Mail-Serie) ===
# Externen Scheduler (z. B. Railway Cron) stündlich auf
# GET /api/cron/automations?secret=$CRON_SECRET zeigen lassen.
# Für schnelle Webhook-Retries zusätzlich jede Minute:
# GET /api/cron/webhooks?secret=$CRON_SECRET
# Für zuverlässige Newsletter-Zustellungen ebenfalls jede Minute:
# GET /api/cron/newsletters?secret=$CRON_SECRET
CRON_SECRET=""
