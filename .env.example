# === Database (required) — Railway Postgres ===
# Use "production" on every live web/worker service. Development and CI have
# their own validation profiles.
AERA_ENVIRONMENT="development"

# This is the privileged system connection used only when no tenant context is
# active (login, platform admin, Stripe inbox, discovery). Every tenant-scoped
# Prisma operation automatically executes `SET LOCAL ROLE aera_app` + the
# tenant GUC in one transaction, so PostgreSQL RLS is actually enforced. The
# DATABASE_URL role remains the privileged platform/migration role and is made
# a member of the non-login aera_app role by `npm run db:deploy`.
# Locally use Railway's PUBLIC proxy URL; on Railway use the INTERNAL URL.
DATABASE_URL="postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway"
DATABASE_INTERNAL_URL="postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway"

# === Auth (required) ===
# 32+ char random secret used to sign session cookies (generate: openssl rand -base64 48)
AUTH_SECRET="change-me-to-a-long-random-string-please-32chars-min"
# AES-256-GCM keyring for TOTP + webhook secrets. First entry is the active key.
# Generate the complete value with: printf 'current:'; openssl rand -base64 32
# Keep the trailing "=" padding and do not use the literal placeholder below.
AERA_DATA_ENCRYPTION_KEYS="current:BASE64_32_BYTE_KEY"

# Local/CI only. /api/dev/qa-login stays 404 without a 32+ char bearer secret
# and is always disabled when NODE_ENV=production.
QA_LOGIN_SECRET=""

# Root domain used for multi-tenant subdomain resolution in production.
NEXT_PUBLIC_ROOT_DOMAIN="aera.so"
APP_URL="http://localhost:3000"
# Trusted fixed origin used only for the proxy's internal custom-domain lookup.
# On Railway this may be APP_URL or a private service URL; never derive it from Host.
DOMAIN_RESOLVER_ORIGIN="http://localhost:3000"
# Optional extra barrier for /admin. This list never grants admin rights; the
# user must additionally have User.platformRole=ADMIN, verified e-mail + TOTP.
# Leave empty to rely on those three durable DB checks.
PLATFORM_ADMIN_EMAILS=""

# === Stripe (required in production) ===
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Fixed monthly Stripe Prices for the creator plans. Required in production;
# local/test environments fall back to server-owned price_data.
STRIPE_CREATOR_STARTER_PRICE_ID="price_..."
STRIPE_CREATOR_PRO_PRICE_ID="price_..."
STRIPE_CREATOR_SCALE_PRICE_ID="price_..."
# Platform fee percentage (3-5% per plan)
AERA_PLATFORM_FEE_PERCENT="5"

# === Email / Newsletter (required in production) ===
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
EMAIL_FROM="Aera <noreply@aera.so>"

# === AI (optional – upgrades recommendations from heuristic to embeddings) ===
# Primary provider: Google Gemini. GEMINI_MODEL powers text generation
# (recommendation reasons), GEMINI_EMBED_MODEL the semantic-search embeddings.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-flash-lite"
GEMINI_EMBED_MODEL="text-embedding-004"
# Image generation & editing for the assistant's "Bild" mode.
GEMINI_IMAGE_MODEL="gemini-3.1-flash-image"
# Fallback provider (used only if GEMINI_API_KEY is empty):
OPENAI_API_KEY=""

# === Streaming (optional) ===
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_URL=""

# === Storage: Railway S3-compatible bucket (Avatare, Uploads) ===
# Aus dem Railway-Bucket-Service übernehmen. Ohne diese Werte landen Uploads
# lokal in public/uploads (nur für Entwicklung).
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Buckets müssen privat bleiben. Uploads werden über den autorisierten
# /api/media-Proxy ausgeliefert; keine public-read ACL konfigurieren.
S3_ACL=""

# Production uploads remain quarantined until a ClamAV INSTREAM scan passes.
# Configure StreamMaxLength >= 600M in the private ClamAV service.
CLAMAV_HOST=""
CLAMAV_PORT="3310"

# === Redis (required in production – distributed rate limits + realtime) ===
REDIS_URL=""

# === Web-Push (optional – aktiviert Push-Benachrichtigungen) ===
# Erzeugen mit: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# === Automations-Cron (Onboarding-E-Mail-Serie) ===
# 32+ zufällige Zeichen (erzeugen: openssl rand -base64 48). Railway führt
# `node scripts/cron.mjs` alle fünf Minuten aus; der Runner nutzt ausschließlich
# POST + `Authorization: Bearer <CRON_SECRET>`. Secrets niemals in URLs setzen.
CRON_SECRET=""
# Nur im Railway-Cron-Service: auf die generierte Domain des Web-Service setzen,
# z. B. `https://${{web.RAILWAY_PUBLIC_DOMAIN}}`. So hängt der Runner nicht von
# DNS-/Weiterleitungsfehlern der öffentlichen Custom Domain ab. Fallback: APP_URL.
CRON_TARGET_URL=""

# === Separater PostgreSQL-Backup-Service (railway.backup.toml) ===
# Öffentlicher age-Empfänger; der private Schlüssel bleibt OFF Railway.
BACKUP_AGE_RECIPIENT=""
# Eigenständiger, versionsgeschützter Bucket außerhalb des primären Railway-Projekts.
BACKUP_S3_ENDPOINT=""
BACKUP_S3_REGION="auto"
BACKUP_S3_BUCKET=""
BACKUP_S3_ACCESS_KEY_ID=""
BACKUP_S3_SECRET_ACCESS_KEY=""
BACKUP_S3_PREFIX="postgres"
# Nur beim isolierten Restore-Drill setzen:
RESTORE_DATABASE_URL=""
RESTORE_DRILL_CONFIRM=""
BACKUP_AGE_IDENTITY_FILE=""
