{
  "name": "aera",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.0.0 <25",
    "npm": ">=11.0.0 <12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --quiet",
    "check": "npm run lint && npm run typecheck && npm test",
    "ci": "npm run check && npm run build",
    "env:check": "tsx scripts/validate-env.ts --profile=production",
    "env:check:ci": "tsx scripts/validate-env.ts --profile=ci",
    "env:check:development": "tsx scripts/validate-env.ts --profile=development",
    "prestart": "npm run env:check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:predeploy": "prisma migrate deploy && tsx scripts/apply-rls.ts",
    "db:studio": "prisma studio",
    "db:rls": "tsx scripts/apply-rls.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:ci": "tsx scripts/seed-ci.ts",
    "db:smoke:ci": "npm run db:seed:ci && npm run db:test-rls && npm run db:test-credits && npm run db:test-webhooks && npm run db:test-automations && npm run db:test-newsletters",
    "db:test": "tsx scripts/test-database.ts",
    "db:test-credits": "tsx scripts/test-credit-reservations.ts",
    "db:test-webhooks": "tsx scripts/test-webhook-outbox.ts",
    "db:test-automations": "tsx scripts/test-automation-outbox.ts",
    "db:test-newsletters": "tsx scripts/test-newsletter-outbox.ts",
    "db:test-rls": "tsx scripts/test-rls-enforcement.ts",
    "db:backup": "node scripts/backup-database.mjs",
    "db:restore-drill": "node scripts/restore-drill.mjs",
    "security:encrypt-secrets": "tsx scripts/encrypt-sensitive-data.ts",
    "db:snap-prices": "tsx scripts/snap-prices-to-apple.ts",
    "admin:grant": "tsx scripts/platform-admin.ts grant",
    "admin:revoke": "tsx scripts/platform-admin.ts revoke",
    "setup": "prisma generate && prisma migrate deploy && tsx scripts/apply-rls.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@aws-crypto/sha256-browser": "^5.2.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.0",
    "ioredis": "^5.11.1",
    "jose": "^6.1.0",
    "next": "16.2.9",
    "next-intl": "^4.13.1",
    "pg": "^8.16.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanitize-html": "^2.17.5",
    "server-only": "^0.0.1",
    "stripe": "^19.0.0",
    "tsx": "^4.20.0",
    "web-push": "^3.6.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.7"
  }
}
