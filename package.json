{
  "name": "aera",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:rls": "tsx scripts/apply-rls.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:test": "tsx scripts/test-database.ts",
    "db:test-credits": "tsx scripts/test-credit-reservations.ts",
    "db:test-webhooks": "tsx scripts/test-webhook-outbox.ts",
    "db:test-automations": "tsx scripts/test-automation-outbox.ts",
    "db:test-newsletters": "tsx scripts/test-newsletter-outbox.ts",
    "db:test-rls": "tsx scripts/test-rls-enforcement.ts",
    "setup": "prisma generate && prisma migrate deploy && tsx scripts/apply-rls.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.0",
    "ioredis": "^5.11.1",
    "jose": "^6.1.0",
    "next": "16.2.9",
    "next-intl": "^4.13.1",
    "pg": "^8.16.0",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanitize-html": "^2.17.5",
    "server-only": "^0.0.1",
    "stripe": "^19.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/web-push": "^3.6.4",
    "prisma": "^7.8.0",
